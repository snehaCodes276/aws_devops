pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-dev"

        IMAGE_TAG = "${BUILD_NUMBER}"
        APP_DIR = 'web'
    }

    options {
        timestamps()
    }

    stages {

        stage('Clean') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Structure') {
            steps {
                sh '''
                echo "Workspace:"
                ls -la

                echo "Web folder:"
                ls -la ${APP_DIR}
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                    npm install || true
                    '''
                }
            }
        }

        stage('Tests') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                    if npm run | grep -q test; then
                        npm test || true
                    else
                        echo "No tests found, skipping"
                    fi
                    '''
                }
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                    /opt/sonar-scanner/bin/sonar-scanner \
                      -Dsonar.projectKey=web \
                      -Dsonar.sources=web
                    '''
                }
            }
        }

        stage('OWASP Scan') {
            steps {
                sh '''
                if [ -d /opt/dependency-check/bin ]; then
                    /opt/dependency-check/bin/dependency-check.sh \
                    --project web --scan web --out . || true
                else
                    echo "OWASP not installed"
                fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                    docker build -t web:${IMAGE_TAG} .
                    '''
                }
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'aws-creds',
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker tag web:${IMAGE_TAG} ${ECR_DEV}:${IMAGE_TAG}
                    docker push ${ECR_DEV}:${IMAGE_TAG}
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ WEB pipeline SUCCESS"
        }
        failure {
            echo "❌ WEB pipeline FAILED"
        }
    }
}
